<!DOCTYPE html>
<html>
<head>
    <title>Edit Buku - Smart Library</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600&display=swap" rel="stylesheet">
    <style>
        /* Animasi ala Apple: Muncul perlahan dari bawah */
        @keyframes fadeInUp {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }

        body {
            font-family: 'Inter', sans-serif;
            background: linear-gradient(135deg, #fdfbfb 0%, #ebedee 100%);
            margin: 0;
            padding: 50px 20px;
            color: #1d1d1f;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 80vh; /* Memastikan form ada di tengah layar */
        }

        /* Glassmorphism Card */
        .container {
            width: 100%;
            max-width: 450px; /* Form edit lebih ramping biar proporsional */
            background: rgba(255, 255, 255, 0.6);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border-radius: 24px;
            padding: 40px;
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.08);
            border: 1px solid rgba(255, 255, 255, 0.5);
            /* Panggil animasi di sini */
            animation: fadeInUp 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards; 
        }

        h1 {
            text-align: center;
            font-weight: 600;
            font-size: 1.8rem;
            margin-top: 0;
            margin-bottom: 30px;
            letter-spacing: -0.03em;
        }

        .form-group {
            margin-bottom: 20px;
        }

        label {
            display: block;
            font-weight: 600;
            margin-bottom: 8px;
            color: #86868b;
            font-size: 0.9rem;
        }

        input {
            width: 100%;
            padding: 14px 16px;
            border-radius: 12px;
            border: 1px solid #d2d2d7;
            background: rgba(255,255,255,0.8);
            font-size: 1rem;
            font-family: 'Inter', sans-serif;
            transition: all 0.3s ease;
            outline: none;
            box-sizing: border-box; 
        }

        input:focus {
            border-color: #0071e3;
            box-shadow: 0 0 0 4px rgba(0, 113, 227, 0.2);
            background: #ffffff;
        }

        .btn-container {
            display: flex;
            gap: 12px;
            margin-top: 35px;
        }

        /* Tombol sejajar dan proporsional */
        button, .btn-cancel {
            flex: 1;
            text-align: center;
            text-decoration: none;
            padding: 14px;
            border-radius: 12px;
            font-size: 1rem;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.2s ease;
            border: none;
        }

        .btn-save {
            background-color: #0071e3;
            color: white;
        }

        .btn-save:hover {
            background-color: #0077ed;
            transform: scale(1.03);
        }

        /* Tombol sekunder (Batal) dengan warna abu-abu elegan */
        .btn-cancel {
            background-color: rgba(0, 0, 0, 0.05);
            color: #1d1d1f;
        }

        .btn-cancel:hover {
            background-color: rgba(0, 0, 0, 0.1);
        }
    </style>
</head>
<body>

<div class="container">
    <h1>Edit Data Buku</h1>
    <form action="/update-buku/<%= buku.id %>" method="POST">
        <div class="form-group">
            <label>Judul Buku</label>
            <input type="text" name="judul" value="<%= buku.judul %>" required>
        </div>
        <div class="form-group">
            <label>Nama Penulis</label>
            <input type="text" name="penulis" value="<%= buku.penulis %>" required>
        </div>
        
        <div class="btn-container">
            <a href="/buku" class="btn-cancel">Batal</a>
            <button type="submit" class="btn-save">Simpan Perubahan</button>
        </div>
    </form>
</div>

</body>
</html>