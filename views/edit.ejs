<!DOCTYPE html>
<html>
<head>
    <title>Edit Buku</title>
    <style>
        body { font-family: sans-serif; text-align: center; margin-top: 50px; }
        form { display: inline-block; text-align: left; padding: 20px; border: 1px solid #ddd; border-radius: 8px; }
        input { display: block; margin: 10px 0; padding: 8px; width: 250px; }
        button { background: #ffc107; border: none; padding: 10px; width: 100%; cursor: pointer; border-radius: 5px; }
    </style>
</head>
<body>
    <h1>Edit Data Buku</h1>
    <form action="/update-buku/<%= buku.id %>" method="POST">
        <label>Judul Buku:</label>
        <input type="text" name="judul" value="<%= buku.judul %>" required>
        <label>Penulis:</label>
        <input type="text" name="penulis" value="<%= buku.penulis %>" required>
        <button type="submit">Simpan Perubahan</button>
    </form>
    <br><a href="/buku">Batal</a>
</body>
</html>